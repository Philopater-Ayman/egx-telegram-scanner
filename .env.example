GEMINI_API_KEY=replace_with_new_rotated_key
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=replace_with_openrouter_key
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODELS=deepseek/deepseek-v4-flash:free,nvidia/nemotron-3-super-120b-a12b:free
TELEGRAM_BOT_TOKEN=replace_with_new_rotated_token
TELEGRAM_CHAT_ID=replace_with_your_chat_id
SEND_TELEGRAM=true
